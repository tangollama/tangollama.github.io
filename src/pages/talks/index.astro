---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import PageLayout from '../../components/PageLayout.jsx';
import { Container, Card } from 'react-bootstrap';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const talks = (await getCollection('talks')).sort((a, b) => {
	const aDate = a.data.date ?? a.data.pubDate ?? new Date(0);
	const bDate = b.data.date ?? b.data.pubDate ?? new Date(0);
	return bDate.valueOf() - aDate.valueOf();
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Talks | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<PageLayout client:load>
			<Container className="pt-3" fluid>
				<h2 class="mb-4">Talks</h2>
				<Container
					fluid
					className="p-3 w-auto text-left d-flex flex-wrap justify-content-center"
				>
					{talks.map((talk) => (
						<div class="p-3">
							<Card className="card-container" href={`/talks/${talk.id}`} as="a">
								{talk.data.heroImage && (
									<Card.Img src={talk.data.heroImage} className="h-50" />
								)}
								<Card.Body className="pt-3">
									<Card.Title>
										<h4>{talk.data.title}</h4>
									</Card.Title>
									{talk.data.subTitle && (
										<Card.Subtitle className="mb-2 text-muted">
											{talk.data.subTitle}
										</Card.Subtitle>
									)}
									{talk.data.excerpt && (
										<Card.Text>{talk.data.excerpt}</Card.Text>
									)}
								</Card.Body>
							</Card>
						</div>
					))}
				</Container>
			</Container>
		</PageLayout>
	</body>
</html>
