{
  "name": "astro-joelworralldotcom",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "prebuild": "npm run build:css",
    "build:css": "sass src/styles:src/styles --no-source-map",
    "watch:css": "sass --watch src/styles:src/styles --no-source-map",
    "dev:all": "concurrently -k \"npm run watch:css\" \"npm run dev\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.12",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.16.0",
    "bootstrap": "^5.3.8",
    "disqus-react": "^1.1.7",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "eslint-plugin-astro": "^1.5.0",
    "prettier": "^3.6.2",
    "sass": "^1.94.2"
  }
